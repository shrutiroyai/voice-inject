# Voice Inject Environment Configuration
# Copy this to .env and customize if needed

# AWS Configuration
AWS_REGION=us-west-2
BEDROCK_MODEL=us.anthropic.claude-3-5-haiku-20241022-v1:0

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=3000

# UI Configuration
UI_PORT=5173

# Note: AWS credentials should be configured via:
